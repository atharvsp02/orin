# Self-hosted Cognee OSS — NOT Cogwit. Verified working config (cognee 1.2.2).

ENABLE_BACKEND_ACCESS_CONTROL=true
COGNEE_SKIP_CONNECTION_TEST=true

# --- LLM (routed via LiteLLM) ---
# PIN the model: Cognee's default gemini-2.0-flash had zero quota in testing.
# Use a PAID tier for ingestion — the free Gemini tier caps at ~20 generations/day.
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.5-flash
LLM_API_KEY=
GEMINI_API_KEY=

# DeepSeek alternative (OpenAI-compatible, via LiteLLM custom):
# LLM_PROVIDER=custom
# LLM_MODEL=deepseek/deepseek-chat
# LLM_ENDPOINT=https://api.deepseek.com/v1
# LLM_API_KEY=

# --- Embeddings ---
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_DIMENSIONS=3072
EMBEDDING_API_KEY=

# --- Persistent storage (mounted volume) ---
DATA_ROOT_DIRECTORY=/data
SYSTEM_ROOT_DIRECTORY=/data/system
