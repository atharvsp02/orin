# Orin bot
PORT=3000

# Postgres for pg-boss queue + app tables (installations, decision_records, tenant_config)
DATABASE_URL=postgres://user:pass@localhost:5432/orin

# GitHub App credentials
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=./github-app.pem
GITHUB_WEBHOOK_SECRET=

# Dashboard identity providers. Unconfigured providers stay hidden.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# Slack connector
SLACK_SIGNING_SECRET=
SLACK_STATE_SECRET=

# Linear connector
LINEAR_WEBHOOK_SECRET=

# Google Drive connector
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=

# Browser origin used for OAuth callbacks
WEB_ORIGIN=http://localhost:3100

# Self-hosted Cognee engine
COGNEE_BASE_URL=http://127.0.0.1:8000

# 32+ char secret used to encrypt per-tenant Cognee API keys at rest
ORIN_SECRET=

# App-layer LLM (Vercel AI SDK) for comment drafting + PR-resemblance judgment.
# Per-tenant provider is stored in tenant_config; set the matching key(s) here.
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
# Optional model overrides: ORIN_GOOGLE_MODEL / _OPENAI_MODEL / _DEEPSEEK_MODEL / _OPENROUTER_MODEL
