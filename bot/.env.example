# CodeGuard bot
PORT=3000

# Postgres for pg-boss queue + app tables (installations, decision_records, tenant_config)
DATABASE_URL=postgres://user:pass@localhost:5432/codeguard

# GitHub App credentials
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Self-hosted Cognee engine (private URL — reached over the VM network / tunnel)
COGNEE_BASE_URL=http://127.0.0.1:8000

# 32+ char secret used to encrypt per-tenant Cognee API keys at rest
CODEGUARD_SECRET=

# App-layer LLM (Vercel AI SDK) for comment drafting + PR-resemblance judgment.
# Per-tenant provider is stored in tenant_config; set the matching key(s) here.
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
# Optional model overrides: CODEGUARD_GOOGLE_MODEL / _OPENAI_MODEL / _DEEPSEEK_MODEL / _OPENROUTER_MODEL
