{
  "name": "orin-bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Orin GitHub App — webhook listener + async workers.",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "mcp": "node dist/mcp.js",
    "mcp:http": "MCP_HTTP=1 node dist/mcp.js",
    "slack": "node dist/slack.js",
    "linear": "node dist/linear.js",
    "dev": "node --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsc && node test/access.test.mjs && node test/connectors.test.mjs && node test/dashboard.test.mjs && node test/patch.test.mjs && node test/commands.test.mjs && node test/pipeline.test.mjs && node test/queues.test.mjs",
    "test:integration": "tsc && node test/integration/db.mjs && node test/integration/cognee.mjs"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^3.0.3",
    "@ai-sdk/google": "^4.0.6",
    "@ai-sdk/openai": "^4.0.5",
    "@linear/sdk": "^88.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slack/bolt": "^4.7.3",
    "ai": "^7.0.11",
    "dotenv": "^17.4.2",
    "octokit": "^5.0.5",
    "pg": "^8.22.0",
    "pg-boss": "^10.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "typescript": "^5.9.3"
  }
}
