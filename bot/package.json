  },
  "dependencies": {
    "@ai-sdk/deepseek": "^3.0.3",
    "@ai-sdk/google": "^4.0.6",
    "@ai-sdk/openai": "^4.0.5",
    "ai": "^7.0.11",
    "dotenv": "^17.4.2",
    "octokit": "^5.0.5",
    "pg": "^8.22.0",
    "pg-boss": "^10.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "typescript": "^5.9.3"
  }
}
