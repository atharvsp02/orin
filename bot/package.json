{
  "name": "codeguard-bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "CodeGuard GitHub App — webhook listener + async workers.",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --watch src/index.ts",
    "typecheck": "tsc --noEmit",
